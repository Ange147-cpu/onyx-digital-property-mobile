{
  "expo": {
    "name": "Onyx Digital Property",
    "slug": "onyx-digital-property",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "onyx",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.0"
          }
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.onyx.digitalproperty"
    },
    "android": {
      "package": "com.onyx.digitalproperty",
      "adaptiveIcon": {
        "backgroundColor": "#0BA1628"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "eas": {
        "projectId": "36ab0722-c5ef-44bf-98f2-ce7c8b4e3771"
      }
    }
  }
}