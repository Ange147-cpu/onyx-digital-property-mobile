{
  "expo": {
    "name": "Onyx Digital Property",
    "slug": "onyx-digital-property",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "onyx",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.onyx.digitalproperty"
    },
    "android": {
      "package": "com.onyx.digitalproperty",
      "adaptiveIcon": {
        "backgroundColor": "#0A1628"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c74c5842-ccd5-41b7-a1d2-c8f743ddb82e"
      }
    },
    "owner": "onyx-digital"
  }
}
