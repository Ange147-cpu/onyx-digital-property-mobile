{
  "expo": {
    "name": "Onyx Digital Property",
    "slug": "onyx-digital-property",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "onyx",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.onyx.digitalproperty"
    },
    "android": {
      "package": "com.onyx.digitalproperty",
      "adaptiveIcon": {
        "backgroundColor": "#0BA1628"
      },
      "buildProperties": {
        "kotlinVersion": "2.1.0"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    }
  }
}